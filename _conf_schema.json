{
  "state_settings": {
    "description": "状态机设置",
    "type": "object",
    "items": {
      "min_state_duration": {
        "description": "状态最短持续时间（秒）",
        "type": "int",
        "default": 1800,
        "hint": "每个状态至少持续多久才可能切换，默认1800秒（30分钟）"
      },
      "transition_rate": {
        "description": "状态切换速率",
        "type": "float",
        "default": 0.05,
        "hint": "每小时增加的切换概率，默认0.05"
      },
      "max_transition_chance": {
        "description": "最大切换概率",
        "type": "float",
        "default": 0.3,
        "hint": "切换概率上限，默认0.3"
      },
      "enable_season": {
        "description": "启用季节系统",
        "type": "bool",
        "default": true
      }
    }
  },
  "proactive_settings": {
    "description": "主动发言设置",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用主动发言",
        "type": "bool",
        "default": true,
        "hint": "与 AstrBot 的「会话隔离」功能冲突，开启会话隔离时请关闭此选项"
      },
      "check_interval_minutes": {
        "description": "检查间隔（分钟）",
        "type": "int",
        "default": 10,
        "hint": "每隔多少分钟检查一次是否主动发言"
      },
      "cooldown_seconds": {
        "description": "发言冷却时间（秒）",
        "type": "int",
        "default": 2700,
        "hint": "两次主动发言之间的最短间隔，默认2700秒（45分钟）"
      },
      "base_chance": {
        "description": "基础发言概率",
        "type": "float",
        "default": 0.15,
        "hint": "每次检查时主动发言的概率，0-1之间"
      },
      "proactive_system_prompt_suffix": {
        "description": "主动发言时的额外提示",
        "type": "text",
        "default": "请用琪露诺的语气，简短地说一两句话。不要太长，像是在群里随口说的。"
      }
    }
  },
  "group_sessions": {
    "description": "主动发言目标群聊 session 列表",
    "type": "text",
    "default": "",
    "hint": "每行一个 session，格式为 平台ID:GroupMessage:群号。例如 chatbot1(aiocqhttp):GroupMessage:123456。也会自动收集群聊中触发过bot的session。"
  },
  "user_info": {
    "description": "用户信息配置",
    "type": "text",
    "default": "",
    "hint": "JSON格式的用户信息，格式：{\"QQ号\": [\"名字\", \"描述\"]}。留空则使用代码中的默认值。"
  },
  "memory_settings": {
    "description": "记忆系统设置",
    "type": "object",
    "items": {
      "enable_core_memory": {
        "description": "启用核心记忆",
        "type": "bool",
        "default": true,
        "hint": "启用后琪露诺会动态更新对每个人的印象"
      },
      "enable_recall_memory": {
        "description": "启用回忆记忆",
        "type": "bool",
        "default": true,
        "hint": "启用后琪露诺会记住历史对话并在相关话题时回忆"
      },
      "core_memory_update_threshold": {
        "description": "核心记忆更新阈值",
        "type": "int",
        "default": 15,
        "hint": "与某用户对话多少条后触发 LLM 更新印象"
      },
      "buffer_limit": {
        "description": "回忆压缩阈值",
        "type": "int",
        "default": 15,
        "hint": "每攒满多少轮对话触发一次 LLM 摘要压缩"
      },
      "recall_search_top_k": {
        "description": "回忆检索数量",
        "type": "int",
        "default": 3,
        "hint": "每次对话最多检索几条相关回忆"
      },
      "allow_stranger_profile": {
        "description": "允许陌生人自动建立档案",
        "type": "bool",
        "default": true,
        "hint": "关闭后只有种子数据中的用户会被核心记忆记住"
      }
    }
  },
  "debug_settings": {
    "description": "调试设置",
    "type": "object",
    "items": {
      "show_full_prompt": {
        "description": "显示完整提示词",
        "type": "bool",
        "default": false,
        "hint": "开启后「琪露诺状态」指令会额外输出发送给 LLM 的完整 system prompt，用于排查句式固化等问题"
      }
    }
  },
  "affinity_settings": {
    "description": "好感度设置",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用好感度系统",
        "type": "bool",
        "default": true
      },
      "boredom_window": {
        "description": "腻了检测窗口（秒）",
        "type": "int",
        "default": 300,
        "hint": "在多少秒的时间窗口内统计连续对话次数"
      },
      "boredom_threshold": {
        "description": "腻了触发阈值",
        "type": "int",
        "default": 12,
        "hint": "窗口内超过多少次对话开始觉得腻，超过两倍则明显敷衍"
      }
    }
  },
  "meme_settings": {
    "description": "表情包设置",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用自动表情包",
        "type": "bool",
        "default": true,
        "hint": "启用后琪露诺会根据回复情绪概率发送表情包"
      },
      "probability": {
        "description": "发送概率",
        "type": "float",
        "default": 0.07,
        "hint": "每次回复时发送表情包的概率，0-1之间"
      }
    }
  }
}
